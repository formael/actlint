{
  "name": "actlint-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "actlint — a static action-risk linter for MCP servers. Reads a server's advertised tools, derives an honest action-risk profile, compares it against what each tool declares, and reports the gaps. It never runs, routes, blocks, or executes anything.",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" run build",
    "clean": "pnpm -r --filter \"./packages/*\" run clean",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "biome check --error-on-warnings .",
    "lint:fix": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "guard:purity": "tsx scripts/check-purity.ts",
    "guard:sdk": "tsx scripts/check-sdk-boundary.ts",
    "guard:determinism": "tsx scripts/check-determinism.ts",
    "guard:vocabulary": "tsx scripts/check-vocabulary-data.ts",
    "guards": "pnpm guard:purity && pnpm guard:sdk && pnpm guard:determinism && pnpm guard:vocabulary",
    "eval": "pnpm --filter @formael/actlint-eval run eval",
    "check": "pnpm typecheck && pnpm lint && pnpm test && pnpm guards",
    "gate": "pnpm build && pnpm check && pnpm eval",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish",
    "check-npm-name": "tsx scripts/check-npm-name.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@changesets/cli": "^2.29.7",
    "@types/node": "^26.1.0",
    "@vitest/coverage-v8": "^4.1.10",
    "fast-check": "^4.8.0",
    "tsup": "^8.3.5",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vite": "^7.3.6",
    "vitest": "^4.1.10"
  }
}
