exports[`sarifReporter (SARIF 2.1.0) > renders a spotless server 1`] = `
"{
  "version": "2.1.0",
  "$schema": "https://json.schemastore.org/sarif-2.1.0.json",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "actlint",
          "version": "0.1.0",
          "rules": []
        }
      },
      "originalUriBaseIds": {
        "SERVER": {
          "uri": "https://example.com/.well-known/mcp"
        }
      },
      "properties": {
        "coverage": {
          "assessedTools": 5,
          "unassessedTools": 0,
          "annotatedTools": 5,
          "unassessedToolNames": []
        }
      },
      "results": []
    }
  ]
}
"
`;

