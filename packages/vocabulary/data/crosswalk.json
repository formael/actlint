      "nist": ["AI-RMF:MEASURE"],
      "mcpField": ["readOnlyHint"]
    },
    "destructive-unflagged": {
      "owaspAsi": ["ASI02:2026"],
      "owaspMcp": ["MCP02"],
      "cosaiOasis": ["operational-visibility"],
      "euAiAct": ["Art.14", "Art.15"],
      "nist": ["AI-RMF:MEASURE"],
      "mcpField": ["destructiveHint"]
    },
    "external-reach-undeclared": {
      "owaspAsi": ["ASI02:2026"],
      "owaspMcp": ["MCP02"],
      "cosaiOasis": ["operational-visibility"],
      "euAiAct": ["Art.12", "Art.14", "Art.26"],
      "nist": ["AI-RMF:MAP"],
      "mcpField": ["openWorldHint"]
    },
    "destructive-absent": {
