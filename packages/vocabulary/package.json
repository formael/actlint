{
  "name": "@formael/action-risk-vocabulary",
  "version": "0.2.0",
  "description": "PURE DATA. The action-risk vocabulary, MCP-hint mapping, and standards crosswalk that back actlint. JSON-Schema'd and independently versioned so any tool can consume it as data, never code.",
  "keywords": [
    "mcp",
    "action-risk",
    "vocabulary",
    "owasp",
    "standards-crosswalk",
    "actlint"
  ],
  "license": "Apache-2.0",
  "author": "Formael",
  "homepage": "https://github.com/formael/actlint/tree/main/packages/vocabulary#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/formael/actlint.git",
    "directory": "packages/vocabulary"
  },
  "bugs": {
    "url": "https://github.com/formael/actlint/issues"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema/vocabulary.schema.json": "./schema/vocabulary.schema.json",
    "./schema/mcp-mapping.schema.json": "./schema/mcp-mapping.schema.json",
    "./schema/crosswalk.schema.json": "./schema/crosswalk.schema.json",
    "./schema/severity-policy.schema.json": "./schema/severity-policy.schema.json",
    "./data/vocabulary.json": "./data/vocabulary.json",
    "./data/mcp-mapping.json": "./data/mcp-mapping.json",
    "./data/crosswalk.json": "./data/crosswalk.json",
    "./data/severity-policy.json": "./data/severity-policy.json"
  },
  "files": [
    "dist",
    "schema",
    "data",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "zod": "^4.4.3"
  }
}
