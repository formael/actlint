{
  "name": "@formael/actlint-core",
  "version": "0.0.0",
  "private": true,
  "description": "PURE. manifest + vocabulary -> profiles -> findings. No I/O, no clock, no randomness, no model. The `./contracts` sub-path is the ONLY surface mcp-fetch may import.",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./contracts": {
      "types": "./dist/contracts/index.d.ts",
      "import": "./dist/contracts/index.js"
    }
  },
  "files": [
    "dist",
    "schema"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@formael/action-risk-vocabulary": "workspace:*",
    "zod": "^4.4.3"
  }
}
