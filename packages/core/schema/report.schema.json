                      "properties": {
                        "id": {
                          "type": "string",
                          "minLength": 1
                        },
                        "weight": {
                          "type": "string",
                          "enum": [
                            "definitive",
                            "strong",
                            "weak"
                          ]
                        }
                      },
                      "required": [
                        "id",
                        "weight"
