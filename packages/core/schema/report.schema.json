        "underDeclared": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "undeclared": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "overDeclared": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
