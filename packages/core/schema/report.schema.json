  "type": "object",
  "properties": {
    "reportSchemaVersion": {
      "type": "string"
    },
    "tool": {
      "type": "string",
      "const": "actlint"
    },
    "actlintVersion": {
      "type": "string"
    },
    "vocabularyVersion": {
      "type": "string"
    },
    "crosswalkVersion": {
      "type": "string"
    },
    "source": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "live"
            },
            "transport": {
              "type": "string",
